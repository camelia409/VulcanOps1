# Base URL for the VulcanOps backend API.
# Development (Vite proxy): leave unset or use an empty value.
# Production (Render / Vercel): set to the full backend origin, e.g.
#   https://your-backend.onrender.com
# Do not include a trailing slash or /api path.
VITE_API_URL=https://your-backend.onrender.com
