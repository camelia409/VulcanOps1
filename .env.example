# Application
APP_ENV=development
SECRET_KEY=change-me-in-production

# PostgreSQL — individual vars (config also supports DATABASE_URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vulcanops
POSTGRES_USER=vulcanops
POSTGRES_PASSWORD=vulcanops

# Redis — individual vars (config also supports REDIS_URL)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# InfluxDB — individual vars (config also supports INFLUX_URL)
INFLUXDB_HOST=localhost
INFLUXDB_PORT=8086
INFLUXDB_ORG=vulcanops
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=change-me-in-production

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# OpenRouter LLM
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat-v3-0324
LLM_TIMEOUT=20.0
