# Application
APP_ENV=production
SECRET_KEY=change-me-in-production

# Database (Render provides this as a single URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Or use individual PostgreSQL vars
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=vulcanops
# POSTGRES_USER=vulcanops
# POSTGRES_PASSWORD=vulcanops

# InfluxDB (Render / InfluxDB Cloud URL, or local host/port)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=change-me-in-production
INFLUX_ORG=vulcanops
INFLUX_BUCKET=telemetry

# Redis (optional; set REDIS_URL or host/port)
# REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS — comma-separated, no spaces between entries
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# LLM provider (OpenAI-compatible endpoint)
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_MODEL=kimi-k2-0905-preview
LLM_TIMEOUT_SECONDS=30
